{
	"$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 120
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	},
	"linter": {
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "error",
				"noTemplateCurlyInString": "off"
			},
			"style": {
				"noNonNullAssertion": "error",
				"useImportType": "error"
			}
		}
	},
	"overrides": [
		{
			"includes": ["*.mjs"],
			"linter": {
				"rules": {
					"suspicious": {
						"noTemplateCurlyInString": "off"
					}
				}
			}
		}
	]
}
